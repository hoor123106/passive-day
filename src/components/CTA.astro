---
import '../styles/cta.css';
---

<section class="cta-section">
    <div class="container">
        <div class="cta-box editorial-shadow">
            <div class="blob blob-left"></div>
            <div class="blob blob-right"></div>
            
            <div class="cta-inner">
                <span class="cta-badge">Premium Insights</span>
                <h2 class="cta-heading">Build your financial fortress with expert-led passive income strategies.</h2>
                <p class="cta-subheading">Join over 50,000 professional investors who receive our exclusive market breakdowns every Tuesday and Friday morning.</p>
                
                <form class="cta-form-container">
                    <input type="email" placeholder="Enter your email address" required />
                    <button type="submit">JOIN PASSIVEDAY</button>
                </form>
                
                <p class="cta-footer">NO SPAM. JUST ALPHA. UNSUBSCRIBE ANYTIME.</p>
            </div>
        </div>
    </div>
</section>

